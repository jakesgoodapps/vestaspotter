# ============================================================
#  VestaSpotter — configuration
#  Copy this file to .env and fill in the values for your setup.
# ============================================================

# ---------- Vestaboard ----------
# Get your Read/Write API key from the Vestaboard app
# (Settings → Developer). Requires a Vestaboard+ subscription.
VESTABOARD_API_KEY=

# DRY_RUN=true logs renders but does NOT push to the physical board.
# Useful during initial setup so you can verify behavior. Flip to false
# when you're ready to take over your board.
DRY_RUN=true

# ---------- FlightAware AeroAPI ----------
# Personal tier ($5/mo free credit) is plenty for a typical install.
# Register at https://flightaware.com/commercial/aeroapi/
FLIGHTAWARE_API_KEY=

# ---------- OpenSky Network ----------
# Required for aircraft position data. Register at
# https://opensky-network.org/ for OAuth2 client credentials (4000 calls/day).
# Anonymous (no credentials) works but is rate-limited to ~400/day.
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=
# Legacy fallback if your account hasn't migrated to OAuth yet:
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# ---------- Your observer location ----------
# Lat/lon of your viewing spot — your apartment, house, deck, backyard,
# rooftop, RV, lake cabin, office, wherever. REQUIRED.
#
# Tip: type your address into Google Maps, right-click → "What's here?"
# to get exact coordinates. Or run `python3 configure.py` for an
# interactive wizard that does the geocoding for you.
LATITUDE=
LONGITUDE=

# Compass bearing your viewing direction faces, in degrees.
# 0=N, 90=E, 180=S, 270=W. Use a compass app on your phone.
#
# If you have a 360° open-sky view (yard, deck, rooftop, rural setting),
# set FIELD_OF_VIEW_DEG=360 below — orientation then doesn't matter.
ORIENTATION_DEG=

# ---------- Detection geometry ----------
# Tune these to match your setup. Defaults work for a near-airport
# apartment/house with a single-direction view (the most common case).

# How far out (nautical miles) to detect aircraft.
#   3-5   — typical near a major airport (low approach/departure traffic)
#   10-20 — further from an airport (catches climbing/descending earlier)
#   50+   — spotting cruise-altitude traffic from a rural area
RADIUS_NM=5.0

# Ignore planes flying ABOVE this altitude (feet).
#   8000  — typical near-airport (most relevant traffic is below this)
#   25000 — catch climbing departures from a moderate distance
#   45000 — catch everything including cruise traffic
MAX_ALTITUDE_FT=8000

# Ignore planes flying BELOW this altitude (feet).
#   200   — near a major airport (excludes on-runway / taxiing aircraft)
#   1000  — only airborne aircraft, no ground clutter
#   10000 — far from airports, only care about cruise-level traffic
MIN_ALTITUDE_FT=200

# Angular width of your visible sky, in degrees.
#   120   — a typical single window
#   180   — a wide window or balcony facing one direction
#   270   — corner unit with two adjacent sides of view
#   360   — open backyard, deck, rooftop, or rural setting
FIELD_OF_VIEW_DEG=120

# IANA timezone name for "today" math + quiet hours.
LOCAL_TIMEZONE=America/New_York

# ---------- Polling + prediction ----------
POLL_INTERVAL=20            # seconds between OpenSky polls (lower = faster reaction, more API calls)
HEARTBEAT_INTERVAL=600      # how often to refresh the board with the SAME flight
PREDICT_SECONDS_AHEAD=100   # project trajectories N seconds forward to catch planes BEFORE they enter view

# ---------- Quiet hours (local time, 24h format) ----------
# During this time range, the app skips all polling + pushing.
# Saves API budget overnight when there's no traffic anyway.
QUIET_HOURS_START=00:30
QUIET_HOURS_END=08:00

# ---------- Display ----------
# IATA airport code closest to your observer. Used for:
#   - "ARR/DEP" detection in sightings
#   - The footer row on the board (e.g. "DCA 12 ARR / 8 DEP")
#   - Selecting your airport_rare_{code}.yaml file (drop your own anytime)
AIRPORT_CODE=

# ---------- POTUS detector (opt-in; DC-only) ----------
# When true, the app watches for Park Police helicopters orbiting the
# White House and cross-references factba.se's POTUS schedule to alert
# you about presidential movements. Only useful if you live near DC.
ENABLE_POTUS_DETECTOR=false

# These default to the actual White House. Other US cities don't have an
# equivalent — leave these as-is and just keep ENABLE_POTUS_DETECTOR=false.
POTUS_ORBIT_CENTER_LAT=38.8977
POTUS_ORBIT_CENTER_LON=-77.0365
POTUS_SCHEDULE_FEED_URL=https://media-cdn.factba.se/rss/json/trump/calendar-full.json
